# Discord Reputation Bot - Ortam Değişkenleri
# Bu dosyayı kopyala ve .env olarak yeniden adlandır

# Discord Bot Token'ı (Discord Developer Portal'dan alınır)
DISCORD_TOKEN=your_discord_bot_token_here

# Bot'un uygulama/istemci kimliği (Discord Developer Portal > General Information > Application ID)
CLIENT_ID=your_client_id_here

# Komutların kaydedileceği sunucu kimliği (Test için tek sunucu, prodüksiyonda boş bırak)
# Guild ID'yi almak için sunucuya sağ tıkla > "Sunucu Kimliğini Kopyala"
GUILD_ID=your_guild_id_here
